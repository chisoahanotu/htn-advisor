# Frontend (Vite) env vars — set these in Vercel (and .env.local for local dev).
# With both Supabase vars set the app runs against the real backend;
# without them it runs the in-browser mock demo.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Optional: canonical site URL used for the master QR + share links + exports.
# Defaults to window.location.origin.
VITE_SITE_URL=https://your-sale.vercel.app

# Optional: PostHog analytics (Phase 2). Leave unset to disable.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ---------------------------------------------------------------------------
# Supabase Edge Function secrets (NOT frontend env vars — set with
# `supabase secrets set KEY=value` or in the Supabase dashboard):
#
#   TELEGRAM_BOT_TOKEN        from @BotFather
#   TELEGRAM_CHAT_ID          your chat id (DM the bot after webhook setup — it replies with it)
#   TELEGRAM_WEBHOOK_SECRET   any long random string; also passed to setWebhook
#   ANTHROPIC_API_KEY         for AI listing intake
#   ANTHROPIC_MODEL           optional; defaults to claude-haiku-4-5 (cheap intake).
#                             Set to claude-opus-4-8 for maximum draft quality.
#   SITE_URL                  public site URL (used in buyer emails)
#   RESEND_API_KEY            optional; enables buyer auto-notify emails (Phase 2)
#   RESEND_FROM               optional; e.g. "Moving Sale <sale@yourdomain.com>"
# ---------------------------------------------------------------------------
